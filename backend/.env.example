DJANGO_SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=foresight_db
DB_USER=foresight_user
DB_PASSWORD=foresight_dev_password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Lemon Squeezy billing webhook signing secret (Settings -> Webhooks in the
# Lemon Squeezy dashboard). Required for backend/billing's webhook endpoint
# to accept any request -- without it, every webhook is rejected with 401.
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Local dev/demo super-admin account, seeded by `manage.py seed_demo_data`.
# Set the same username/password in frontend/.env.local as ADMIN_API_USERNAME
# / ADMIN_API_PASSWORD so the Next.js server can call the /api/v1/admin/
# endpoints. Dev-only credential, never used in production.
DJANGO_SUPERADMIN_USERNAME=
DJANGO_SUPERADMIN_PASSWORD=
